{
  "name": "bitburner-ipvgo-engine",
  "version": "1.0.0",
  "private": true,
  "description": "Native / WASM IPvGO engine for Bitburner (JSON API)",
  "type": "module",
  "scripts": {
    "build:wasm": "node build.js",
    "build:native": "cmake -B build -DCMAKE_BUILD_TYPE=Release && cmake --build build --config Release",
    "setup": "node scripts/setup-katago.js",
    "build": "pnpm run build:wasm",
    "server": "node server.js",
    "game:build": "cmake -B build -DCMAKE_BUILD_TYPE=Release && cmake --build build --config Release --target ipvgo_game",
    "game:mcgs": "bash scripts/mcgs.sh",
    "game:selftest": "bash scripts/mcgs.sh selftest",
    "game:bench": "bash scripts/mcgs.sh bench",
    "parity": "node scripts/run-game.js parity temp/parity_cases.json"
  }
}
