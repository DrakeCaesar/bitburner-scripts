{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 16,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "koth-tune-release",
      "displayName": "Koth Tune (Release)",
      "binaryDir": "${sourceDir}/build",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "koth-tune-release",
      "configurePreset": "koth-tune-release",
      "configuration": "Release"
    }
  ]
}
